{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": ["scripts/check-api.ts", "scripts/check-exports.ts", "src/index.ts"],
  "ignorePatterns": ["dist/**", "coverage/**", "node_modules/**"],
  "ignoreDependencies": ["@agent-trail/schema", "@agent-trail/types"],
  "rules": {
    "unresolved-imports": "error",
    "unused-files": "error",
    "unused-exports": "warn",
    "unused-types": "warn"
  },
  "duplicates": {
    "threshold": 0,
    "ignore": [
      "packages/types/src/generated.ts",
      "**/*.test.ts",
      "packages/adapters/src/pi/**",
      "packages/adapters/src/opencode/**"
    ]
  },
  "health": {
    "ignore": ["packages/adapters/src/pi/**", "packages/adapters/src/opencode/**"]
  },
  "production": false
}
