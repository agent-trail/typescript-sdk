{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": ["scripts/check-api.ts", "scripts/check-exports.ts", "src/index.ts"],
  "ignorePatterns": ["dist/**", "coverage/**", "node_modules/**"],
  "rules": {
    "unresolved-imports": "error",
    "unused-files": "error",
    "unused-exports": "warn",
    "unused-types": "warn"
  },
  "duplicates": {
    "threshold": 0,
    "ignore": ["packages/types/src/generated.ts", "packages/core/src/index.ts"]
  },
  "health": {
    "thresholdOverrides": [
      {
        "files": ["packages/core/src/index.ts"],
        "functions": [
          "layoutDiagnostics",
          "toolPairingDiagnostics",
          "userQueryDiagnostics",
          "reconcileSegments",
          "tolerantUnknownPayloadPath",
          "hashDiagnostics",
          "mergeSegments",
          "timestampDiagnostics",
          "sourceRawDiagnostics"
        ],
        "maxCyclomatic": 40,
        "maxCognitive": 75,
        "maxCrap": 300,
        "reason": "Spec conformance validator branches mirror the fixture manifest and are covered by manifest-driven tests."
      }
    ]
  },
  "production": false
}
