{
  "name": "@agent-trail/typescript-sdk",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "check": "bun run --parallel check:biome check:types test check:exports check:spec check:source-types check:declaration-dependent check:fallow",
    "check:api": "bun run build:declarations && bun run check:api:reports",
    "check:api:reports": "bun run scripts/check-api.ts",
    "check:biome": "biome check .",
    "check:changesets": "changeset status --since=origin/main",
    "check:declaration-dependent": "bun run build:declarations && bun run --parallel check:api:reports check:publish:packed",
    "check:exports": "bun run scripts/check-exports.ts",
    "check:fallow": "fallow --fail-on-issues --format compact",
    "check:publish": "bun run build:declarations && bun run check:publish:packed",
    "check:publish:packed": "bun run scripts/check-publish-readiness.ts",
    "check:spec": "bun run scripts/check-spec-artifacts.ts",
    "check:source-types": "bun run scripts/generate-source-types.ts --check",
    "check:types": "tsc --noEmit",
    "build:declarations": "bun run scripts/build-api-declarations.ts",
    "generate:source-types": "bun run scripts/generate-source-types.ts",
    "generate:types": "bun run scripts/generate-types.ts",
    "preview:packages": "pkg-pr-new publish './packages/*'",
    "vendor:spec": "bun run scripts/vendor-spec.ts",
    "test": "bun test --parallel=4"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.3",
    "@biomejs/biome": "2.5.0",
    "@changesets/cli": "2.31.0",
    "@microsoft/api-extractor": "7.58.9",
    "@types/bun": "1.3.14",
    "fallow": "2.95.0",
    "json-schema-to-typescript": "15.0.4",
    "pkg-pr-new": "0.0.75",
    "publint": "0.3.21",
    "typescript": "6.0.3"
  }
}
