{
  "name": "@agent-trail/adapter-kit",
  "version": "0.1.0",
  "description": "Agent Trail shared adapter extraction primitives and source readers.",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./bun-sqlite": {
      "types": "./dist/readers/bun-sqlite-driver.d.ts",
      "default": "./dist/readers/bun-sqlite-driver.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agent-trail/typescript-sdk.git",
    "directory": "packages/adapter-kit"
  },
  "bugs": {
    "url": "https://github.com/agent-trail/typescript-sdk/issues"
  },
  "homepage": "https://github.com/agent-trail/typescript-sdk#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@agent-trail/core": "workspace:*",
    "@agent-trail/source-schemas": "workspace:*",
    "@agent-trail/types": "workspace:*",
    "ajv": "8.20.0",
    "semver": "7.8.4"
  },
  "devDependencies": {
    "@types/semver": "7.7.1"
  }
}
