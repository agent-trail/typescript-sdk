{
  "name": "@agent-trail/core",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./credential-patterns": {
      "types": "./dist/credential-patterns.d.ts",
      "default": "./dist/credential-patterns.js"
    },
    "./identity": {
      "types": "./dist/identity.d.ts",
      "default": "./dist/identity.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@agent-trail/schema": "workspace:*",
    "@agent-trail/types": "workspace:*",
    "ajv": "8.20.0",
    "json-canonicalize": "2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agent-trail/typescript-sdk.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/agent-trail/typescript-sdk/issues"
  },
  "homepage": "https://github.com/agent-trail/typescript-sdk#readme",
  "engines": {
    "node": ">=20"
  }
}
