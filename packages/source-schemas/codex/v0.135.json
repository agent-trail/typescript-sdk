{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-trail.dev/source/codex/v0.135.json",
  "title": "CodexV0_135Record",
  "description": "Codex rollout JSONL record (codex 0.129+ (codex-tui / Codex Desktop / codex_sdk_ts)). Every line is {timestamp, type, payload}. Drift is caught at record-type granularity: unknown top-level type or unknown event_msg/response_item payload type fails validation and is quarantined. Payload fields are intentionally lenient to avoid false quarantine on additive field drift.",
  "type": "object",
  "required": ["type"],
  "properties": {
    "type": {
      "enum": ["session_meta", "turn_context", "event_msg", "response_item", "compacted"]
    },
    "payload": {}
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "event_msg"
          }
        },
        "required": ["type"]
      },
      "then": {
        "required": ["payload"],
        "properties": {
          "payload": {
            "$ref": "#/$defs/eventMsgPayload"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "response_item"
          }
        },
        "required": ["type"]
      },
      "then": {
        "required": ["payload"],
        "properties": {
          "payload": {
            "$ref": "#/$defs/responseItemPayload"
          }
        }
      }
    }
  ],
  "$defs": {
    "eventMsgPayload": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "enum": [
            "agent_message",
            "agent_reasoning",
            "agent_reasoning_raw_content",
            "agent_reasoning_section_break",
            "deprecation_notice",
            "elicitation_request",
            "error",
            "exec_command_begin",
            "exec_command_end",
            "apply_patch_approval_request",
            "exec_approval_request",
            "request_permissions",
            "guardian_warning",
            "hook_completed",
            "hook_started",
            "image_generation_begin",
            "image_generation_end",
            "item_started",
            "mcp_startup_complete",
            "mcp_startup_update",
            "mcp_tool_call_begin",
            "mcp_tool_call_end",
            "model_reroute",
            "model_verification",
            "patch_apply_begin",
            "patch_apply_end",
            "patch_apply_updated",
            "stream_error",
            "task_complete",
            "task_started",
            "thread_goal_updated",
            "token_count",
            "warning",
            "user_message",
            "web_search_begin",
            "web_search_end",
            "context_compacted",
            "item_completed",
            "turn_aborted"
          ]
        }
      }
    },
    "responseItemPayload": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "enum": [
            "custom_tool_call",
            "custom_tool_call_output",
            "function_call",
            "function_call_output",
            "reasoning",
            "tool_search_call",
            "tool_search_output",
            "web_search_call",
            "message"
          ]
        }
      }
    }
  }
}
